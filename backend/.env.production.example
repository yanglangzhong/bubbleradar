# 生产环境变量示例
# 复制本文件为 .env 后填入真实值，并确保不提交到 Git

ENVIRONMENT=production

# PostgreSQL 连接串（Render/Supabase/Railway 提供）
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/bubbleradar
SYNC_DATABASE_URL=postgresql://user:password@host:5432/bubbleradar

# Redis 连接串（Upstash/Render/Railway 提供）
REDIS_URL=redis://default:password@host:6379/0

# 安全：生产环境务必替换为随机长字符串
SECRET_KEY=replace-with-a-random-secret-key-at-least-32-chars
API_KEY=

# CORS：已部署前端地址（只能是 origin，不能带路径），多个用逗号分隔
CORS_ORIGINS=https://lang-6io.pages.dev

# 外部 API 密钥（留空则跳过对应数据源）
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
OPENAI_API_KEY=

# 告警推送（按需填写）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
SERVERCHAN_SENDKEY=
WECHAT_WORK_WEBHOOK=

# 可观测性（可选）
SENTRY_DSN=
