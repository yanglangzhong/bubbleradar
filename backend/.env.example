# 本地开发环境变量示例
# 复制本文件为 .env 后填入真实值

# 数据库（相对项目根目录的 data 文件夹）
DATABASE_URL=sqlite+aiosqlite:///../data/bubbleradar.db
SYNC_DATABASE_URL=sqlite:///../data/bubbleradar.db

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys（请替换为你自己的密钥）
FRED_API_KEY=your-fred-api-key
ALPHA_VANTAGE_API_KEY=your-alphavantage-api-key
OPENAI_API_KEY=your-openai-api-key

# 安全与 CORS
SECRET_KEY=change-me-in-production
API_KEY=
CORS_ORIGINS=["http://localhost","http://localhost:5173"]
ENVIRONMENT=development

# 告警推送（按需填写，留空则禁用）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
SERVERCHAN_SENDKEY=
WECHAT_WORK_WEBHOOK=
