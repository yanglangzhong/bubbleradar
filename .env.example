# Docker Compose 环境变量示例
# 复制本文件为 .env 后填入真实值

# 数据库（Docker 内使用 /app/data 挂载路径）
DATABASE_URL=sqlite+aiosqlite:///app/data/bubbleradar.db
SYNC_DATABASE_URL=sqlite:///app/data/bubbleradar.db

# Redis
REDIS_URL=redis://redis:6379/0

# API Keys（请替换为你自己的密钥）
FRED_API_KEY=your-fred-api-key
ALPHA_VANTAGE_API_KEY=your-alphavantage-api-key

# 安全与 CORS
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost","http://localhost:5173"]
